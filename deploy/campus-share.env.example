# Copy to /etc/campus-share/campus-share.env on the ECS host.
# Do not commit the real file because it contains production credentials.

SPRING_PROFILES_ACTIVE=mysql
# Multi-instance deal lock: SPRING_PROFILES_ACTIVE=mysql,redis
SERVER_PORT=8085

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=campus_share
DB_USER=campus_share
DB_PASSWORD=change-me

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

MEDIA_ROOT=/opt/campus-share/media
MEDIA_URL=/media/
CORS_ORIGINS=http://120.26.174.97

RATE_LIMIT_LOGIN=20
RATE_LIMIT_REGISTER=10
JAVA_OPTS="-Xms256m -Xmx768m"
